{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "check": "tsc --noEmit",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.cjs --runInBand",
    "test:check": "tsc -p tsconfig.test.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:export": "drizzle-kit export",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.13.1",
    "graphql-yoga": "^5.18.1",
    "handlebars": "^4.7.8",
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.5",
    "drizzle-kit": "^0.31.9",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.2",
    "wrangler": "^4.71.0"
  }
}
